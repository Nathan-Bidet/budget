// Schéma Prisma — Budget Familial
// Multi-utilisateur par foyer, rôles admin/membre.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Foyer ────────────────────────────────────────
// Unité de regroupement : un foyer contient des membres, des comptes,
// des catégories et des règles de catégorisation.
model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    User[]
  accounts   Account[]
  categories Category[]
  rules      CategoryRule[]
}

enum Role {
  ADMIN
  MEMBER
}

// ─── Utilisateur ──────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Comptes dont l'utilisateur est titulaire (null = compte commun du foyer)
  accounts     Account[]
  transactions Transaction[] @relation("TransactionOwner")

  @@index([householdId])
}

// ─── Compte bancaire ──────────────────────────────
model Account {
  id        String      @id @default(cuid())
  name      String      // ex: "Compte courant Nathan", "Livret A commun"
  bank      String?     // ex: "BNP", "Boursorama" — utile pour le parser
  type      AccountType @default(CHECKING)
  iban      String?     // stocké masqué si besoin
  isShared  Boolean     @default(false) // compte commun du foyer
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Titulaire (null si compte commun)
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  transactions Transaction[]
  statements   Statement[]

  @@index([householdId])
  @@index([ownerId])
}

enum AccountType {
  CHECKING // compte courant
  SAVINGS  // épargne
  CARD     // carte / crédit
  CASH     // espèces
}

// ─── Relevé importé ───────────────────────────────
// Trace un fichier PDF importé, pour éviter les doublons et journaliser.
model Statement {
  id           String   @id @default(cuid())
  fileName     String
  fileHash     String   // hash du PDF pour détecter les ré-imports
  periodStart  DateTime?
  periodEnd    DateTime?
  importedAt   DateTime @default(now())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([accountId, fileHash])
  @@index([accountId])
}

// ─── Transaction ──────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  date        DateTime // date de l'opération
  label       String   // libellé brut du relevé
  amount      Decimal  @db.Decimal(12, 2) // négatif = dépense, positif = crédit
  currency    String   @default("EUR")
  note        String?  // annotation manuelle
  // Empreinte pour dédoublonnage (date+montant+label normalisé)
  dedupeHash  String
  // true si la catégorie a été fixée/corrigée à la main (protège de l'auto)
  categoryLocked Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Titulaire de la dépense (pour la vue par membre)
  ownerId String?
  owner   User?   @relation("TransactionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  statementId String?
  statement   Statement? @relation(fields: [statementId], references: [id], onDelete: SetNull)

  @@unique([accountId, dedupeHash])
  @@index([accountId])
  @@index([categoryId])
  @@index([ownerId])
  @@index([date])
}

// ─── Catégorie ────────────────────────────────────
model Category {
  id        String   @id @default(cuid())
  name      String   // ex: "Alimentation", "Logement", "Transport"
  color     String   @default("#6366f1")
  icon      String?  // nom d'icône côté frontend
  parentId  String?  // sous-catégorie (hiérarchie simple)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  transactions Transaction[]
  rules        CategoryRule[]

  @@unique([householdId, name])
  @@index([householdId])
}

// ─── Règle de catégorisation ──────────────────────
// Automatisation : si le libellé matche un mot-clé (et éventuellement une
// fourchette de montant), la transaction est rangée dans la catégorie.
// `weight` permet un apprentissage progressif (règles renforcées à l'usage).
model CategoryRule {
  id         String   @id @default(cuid())
  keyword    String   // sous-chaîne recherchée dans le libellé (insensible casse)
  minAmount  Decimal? @db.Decimal(12, 2)
  maxAmount  Decimal? @db.Decimal(12, 2)
  weight     Int      @default(1) // priorité / confiance
  autoLearned Boolean @default(false) // créée par apprentissage vs manuelle
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([categoryId])
}
