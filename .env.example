# ─── Domaine (prod) ───────────────────────────────
DOMAIN=budget.mondomaine.fr
ACME_EMAIL=nathanbidet9@gmail.com

# ─── PostgreSQL ───────────────────────────────────
POSTGRES_USER=budget
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=budget_familial
# URL utilisée par le backend (host = nom du service docker "postgres")
DATABASE_URL=postgresql://budget:change_me_strong_password@postgres:5432/budget_familial?schema=public

# ─── Backend ──────────────────────────────────────
BACKEND_PORT=4000
# Secret pour signer les JWT (générer: openssl rand -hex 32)
JWT_SECRET=change_me_with_openssl_rand_hex_32
# Durée de validité du token
JWT_EXPIRES_IN=7d

# ─── Frontend ─────────────────────────────────────
FRONTEND_PORT=3000
# URL publique de l'API vue par le navigateur
NEXT_PUBLIC_API_URL=https://budget.mondomaine.fr/api
