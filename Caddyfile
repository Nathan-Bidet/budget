# Caddy — reverse proxy interne, HTTP simple (PAS de TLS).
# Le HTTPS est géré en amont par Cloudflare Tunnel : Cloudflare termine le TLS
# à sa périphérie, le tunnel forwarde en HTTP vers ce Caddy, qui route ensuite
# vers le frontend et le backend. Caddy n'a donc pas besoin de Let's Encrypt.

:80 {
	encode gzip

	# Routes API → backend Fastify
	handle /api/* {
		reverse_proxy backend:4000
	}

	# Tout le reste → frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
